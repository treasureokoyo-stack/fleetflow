{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    { "src": "vite.config.js", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "cleanUrls": true,
  "git": {
    "submodules": false
  }
}
